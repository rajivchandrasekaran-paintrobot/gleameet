# GleaMeet Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=chrome-extension://*

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=gleameet
PG_USER=gleameet
PG_PASSWORD=gleameet_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# LLM — defaults point to a local Ollama instance (https://ollama.com)
# To use OpenAI instead, set LLM_BASE_URL=https://api.openai.com/v1 and provide your key.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2
LLM_API_KEY=ollama

# Retention (days)
RETENTION_RAW_TRANSCRIPT=7
RETENTION_DERIVED_FEATURES=30
RETENTION_PROMPTS=90
RETENTION_REPORTS=365

# Retention cleanup interval (milliseconds, default 6 hours)
RETENTION_INTERVAL_MS=21600000
