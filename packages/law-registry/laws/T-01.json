{
  "law_id": "T-01",
  "version": "1.0.0",
  "status": "active",
  "source_family": "Thaler",
  "law_name": "Choice Architecture",
  "description": "Detects too many options presented without recommendation hierarchy.",
  "meeting_relevance": "Too many options can increase decision friction.",
  "observable_inputs": ["option_count_presented", "default_recommendation_present"],
  "trigger_type": "rolling_window",
  "trigger_logic": {
    "all": [
      {"feature": "option_count_presented", "op": "gt", "value": 3},
      {"feature": "default_recommendation_present", "op": "eq", "value": false}
    ]
  },
  "disconfirming_logic": {
    "any": [
      {"feature": "default_recommendation_present", "op": "eq", "value": true},
      {"feature": "option_count_presented", "op": "lte", "value": 2}
    ]
  },
  "prompt_templates_live": [
    {"type": "close", "text": "Narrow to two choices."},
    {"type": "frame", "text": "Structure the options."},
    {"type": "close", "text": "Recommend a default."}
  ],
  "prompt_templates_post": ["You presented many options without narrowing or recommending a default."],
  "confidence_threshold": 0.74,
  "cooldown_seconds": 300,
  "risk_notes": ["Do not imply user is disorganized."],
  "allowed_inferences": ["The choice set may be too complex."]
}
