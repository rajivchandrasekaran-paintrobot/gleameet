{
  "law_id": "C-03",
  "version": "1.0.0",
  "status": "active",
  "source_family": "Cialdini",
  "law_name": "Social Proof",
  "description": "Detects resistance due to unfamiliarity when peer examples could reduce uncertainty.",
  "meeting_relevance": "Peer examples may reduce uncertainty about a change.",
  "observable_inputs": ["peer_example_present", "evidence_reference_present"],
  "trigger_type": "rolling_window",
  "trigger_logic": {
    "all": [
      {"feature": "peer_example_present", "op": "eq", "value": false},
      {"feature": "evidence_reference_present", "op": "eq", "value": false},
      {"feature": "turn_count", "op": "gt", "value": 4}
    ]
  },
  "disconfirming_logic": {
    "any": [
      {"feature": "peer_example_present", "op": "eq", "value": true},
      {"feature": "evidence_reference_present", "op": "eq", "value": true}
    ]
  },
  "prompt_templates_live": [
    {"type": "frame", "text": "Use a peer example."},
    {"type": "frame", "text": "Reference a similar case."},
    {"type": "frame", "text": "Show this isn't unusual."}
  ],
  "prompt_templates_post": ["You advocated for change without referencing comparable examples."],
  "confidence_threshold": 0.69,
  "cooldown_seconds": 300,
  "risk_notes": ["Do not fabricate social proof."],
  "allowed_inferences": ["A comparable example may help."]
}
