{
  "name": "@gleameet/backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "dependencies": {
    "@gleameet/shared": "*",
    "@gleameet/law-registry": "*",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "openai": "^4.73.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.12",
    "supertest": "^6.3.4",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src", "<rootDir>/tests"],
    "moduleNameMapper": {
      "^@gleameet/shared$": "<rootDir>/../shared/src/index.ts",
      "^@gleameet/law-registry$": "<rootDir>/../law-registry/src/index.ts"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "tsconfig": "tsconfig.test.json"
      }]
    }
  }
}
